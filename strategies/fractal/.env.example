# Binance Configuration
BINANCE_SYMBOL=BTC/USDT

# Discord Webhook
DISCORD_WEBHOOK=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Detection Interval (seconds) - default 3600 = 1 hour
DETECTION_INTERVAL=3600

# Active Setups (comma-separated)
ACTIVE_SETUPS=STRICT,MODÉRÉ,FRÉQUENT

# Database Configuration
# SQLite (development)
DB_TYPE=sqlite
DB_PATH=signals.db

# PostgreSQL (production - uncomment to use)
# DB_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/fractal_signals

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Railway Deployment
# Set these when deploying to Railway
# PORT=8000 (automatically set by Railway)
# ENVIRONMENT=production
